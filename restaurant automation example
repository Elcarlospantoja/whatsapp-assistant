      "parameters": {
        "jsCode": "// ==============================================\n// VALIDADOR: Detecta errores sin modificar el mensaje\n// ==============================================\n\nconst agentOutput = $input.first().json;\nconst originalMessage = agentOutput.output || '';\nconst intent = agentOutput.intent || 'CHAT';\nconst chatid = agentOutput.chatid || '';\n\n// Si no hay mensaje, pasar sin error\nif (!originalMessage) {\n  return [{ json: { ...agentOutput, hasError: false, errorDetails: null } }];\n}\n\n// ==============================================\n// Obtener menú real (ajusta el nombre del nodo)\n// ==============================================\nlet menuItems = [];\nlet salsasItems = [];\n\ntry {\n  // Cambia \"Merge menu y salsas\" por el nombre real de tu nodo\n  const menuNode = $('Merge menu y salsas').first();\n  if (menuNode && menuNode.json.menu) {\n    menuItems = menuNode.json.menu;\n    salsasItems = menuNode.json.salsas;\n  }\n} catch (e) {\n  console.error('No se pudo obtener el menú:', e);\n}\n\nif (menuItems.length === 0) {\n  return [{ json: { ...agentOutput, hasError: false, errorDetails: null } }];\n}\n\n// ==============================================\n// Mapas de datos reales\n// ==============================================\nconst productMap = new Map();\nfor (const p of menuItems) {\n  productMap.set(p.nombre.toLowerCase(), {\n    nombre: p.nombre,\n    precio: p.precio,\n    categoria: p.categoria\n  });\n}\n\nconst salsaSet = new Set(salsasItems.map(s => s.nombre.toLowerCase()));\n\n// ==============================================\n// Funciones auxiliares\n// ==============================================\nfunction escapeRegex(str) {\n  return str.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\nconst errors = [];\n\n// 1. Verificar precios de productos mencionados\nfor (const [nombreLower, data] of productMap.entries()) {\n  const regex = new RegExp(`\\\\b${escapeRegex(nombreLower)}\\\\b`, 'i');\n  if (regex.test(originalMessage)) {\n    // Buscar precio mencionado ($140 o 140 pesos)\n    const priceRegex = /(?:\\$|\\b)(\\d{2,3})\\b(?!\\s*\\.\\d)/;\n    const match = originalMessage.match(priceRegex);\n    if (match) {\n      const mentionedPrice = parseInt(match[1]);\n      if (mentionedPrice !== data.precio) {\n        errors.push(`El precio de \"${data.nombre}\" es $${data.precio}, NO $${mentionedPrice}.`);\n      }\n    }\n  }\n}\n\n// 2. Verificar salsas inventadas\nconst lowerMessage = originalMessage.toLowerCase();\nfor (const salsa of salsaSet) {\n  // Si aparece una salsa que no está en el set\n  if (lowerMessage.includes(salsa)) continue;\n  // Detectar frases como \"salsa de X\"\n  const salsaMatch = lowerMessage.match(/salsa\\s+de\\s+([a-záéíóúñ]+)/);\n  if (salsaMatch && !salsaSet.has(salsaMatch[1])) {\n    errors.push(`La salsa \"${salsaMatch[1]}\" no existe. Salsas disponibles: ${Array.from(salsaSet).slice(0, 5).join(', ')}.`);\n    break;\n  }\n}\n\n// 3. Verificar promociones inventadas\nconst promosReales = menuItems\n  .filter(p => p.categoria.includes('Promo') || p.categoria.includes('Oferta'))\n  .map(p => p.nombre.toLowerCase());\nconst promoMatch = originalMessage.match(/(promo|oferta|combo)\\s+([a-záéíóúñ\\s]+)/i);\nif (promoMatch) {\n  const promoName = promoMatch[2].trim().toLowerCase();\n  const exists = promosReales.some(p => promoName.includes(p) || p.includes(promoName));\n  if (!exists && !promoName.includes('lunes')) { // excepción para días\n    errors.push(`La promoción \"${promoMatch[0]}\" no está en el menú. Promociones reales: ${promosReales.slice(0, 3).join(', ')}.`);\n  }\n}\n\nconst hasError = errors.length > 0;\nconst errorDetails = hasError ? errors.join(' ') : null;\n\n// ==============================================\n// Retornar con indicador de error\n// ==============================================\nreturn [{\n  json: {\n    output: originalMessage,\n    intent: intent,\n    chatid: chatid,\n    hasError: hasError,\n    errorDetails: errorDetails,\n    originalAgentOutput: agentOutput\n  }\n}];"

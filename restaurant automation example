        "jsCode": "// ==============================================\n// PREPARAR BASE DE DATOS - Formatear pedido para Supabase\n// ==============================================\n\nconst input = $input.first().json;\n\n// 1. Extraer el JSON del campo 'text' (viene con bloque markdown)\nlet pedidoData = {};\nif (input.text) {\n  let text = input.text;\n  // Limpiar bloque ```json ... ```\n  const jsonMatch = text.match(/```json\\s*([\\s\\S]*?)\\s*```/);\n  if (jsonMatch) {\n    try {\n      pedidoData = JSON.parse(jsonMatch[1]);\n    } catch(e) {\n      console.error('Error parseando JSON:', e);\n    }\n  } else {\n    // Intentar parsear directamente si no hay bloque\n    try {\n      pedidoData = JSON.parse(text);\n    } catch(e) {}\n  }\n} else {\n  pedidoData = input;\n}\n\n// 2. Obtener el chatid desde el nodo 'extraer datos1'\nlet chatid = '';\ntry {\n  const extraerNode = $('extraer datos1').first();\n  if (extraerNode && extraerNode.json.chatid) {\n    chatid = extraerNode.json.chatid;\n  }\n} catch(e) {\n  console.error('No se pudo obtener chatid:', e);\n}\n\n// 3. Formatear items como una sola línea (usando los campos del JSON)\nconst items = pedidoData.items || [];\nconst itemsLine = items.map(item => {\n  const cantidad = item.cant || item.cantidad || 1;\n  const producto = item.prod || item.producto || '';\n  const salsa = item.salsa ? ` (${item.salsa})` : '';\n  return `${cantidad} x ${producto}${salsa}`;\n}).join(', ');\n\n// 4. Construir objeto final para Supabase\nconst supabaseData = {\n  cliente_id: chatid,                                 // clave foránea\n  nombre: pedidoData.nombre || '',\n  direccion: pedidoData.direccion || '',\n  forma_entrega: pedidoData.metodo_entrega || 'domicilio',\n  items: itemsLine,\n  total: pedidoData.total_aproximado || pedidoData.total || 0,\n  notas: pedidoData.notas_extra || pedidoData.notas || '',\n  chatid: chatid                                      // por si acaso\n};\n\nreturn [{ json: supabaseData }];"

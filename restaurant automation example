        "jsCode": "// ==============================================\n// CREAR FEEDBACK PARA EL BOT\n// ==============================================\n\nconst data = $input.first().json;\nconst errorMsg = data.errorDetails;\nconst originalOutput = data.output;\nconst chatid = data.chatid;\n\n// Obtener el mensaje original del cliente desde el nodo 'extraer datos1'\nlet mensajeCliente = '';\ntry {\n  const extraerNode = $('extraer datos1').first();\n  if (extraerNode && extraerNode.json.mensaje) {\n    mensajeCliente = extraerNode.json.mensaje;\n  }\n} catch (e) {\n  mensajeCliente = '(no se pudo recuperar)';\n}\n\n// Obtener el menú contexto (desde el nodo que lo preparó)\nlet menuContext = '';\ntry {\n  const menuContextNode = $('Preparar contexto para Mesero').first();\n  if (menuContextNode && menuContextNode.json.menu_context) {\n    menuContext = menuContextNode.json.menu_context;\n  }\n} catch (e) {\n  menuContext = '(menú no disponible)';\n}\n\n// Construir feedback para el bot\nconst feedbackMessage = `❌ **ERROR EN TU RESPUESTA ANTERIOR**\n\n${errorMsg}\n\n**Contexto:**\n- Cliente preguntó: \"${mensajeCliente}\"\n- Tu respuesta incorrecta fue: \"${originalOutput}\"\n\n**Instrucción:** \nReescribe tu respuesta usando SOLO los datos del menú real que tienes a continuación. No inventes precios, productos ni promociones.\n\n${menuContext}\n\nAhora escribe la respuesta CORREGIDA para el cliente (sin incluir este mensaje de feedback):`;\n\n// Retornar en el formato que espera el Mesero (como si fuera un nuevo mensaje de usuario)\nreturn [{\n  json: {\n    output: feedbackMessage,\n    intent: 'CHAT',  // Forzar CHAT para evitar que se dispare PEDIDO\n    chatid: chatid,\n    nombre: data.originalAgentOutput?.nombre || '',\n    direccion: data.originalAgentOutput?.direccion || '',\n    notas_cliente: data.originalAgentOutput?.notas_cliente || '',\n    menu_context: menuContext,\n    mensaje_usuario: feedbackMessage  // El Mesero usará esto como entrada\n  }\n}];"

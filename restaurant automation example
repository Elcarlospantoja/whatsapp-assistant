        "jsCode": "const inputData = $input.first().json;\nconst rawOutput = inputData.output || \"\";\nconst chatid = inputData.chatid || \"\";\n\n// 1. Buscar etiqueta [INTENT: ...] al final del mensaje (insensible a mayúsculas)\nconst intentRegex = /\\[INTENT:\\s*(\\w+)\\s*\\]/i;\nconst match = rawOutput.match(intentRegex);\n\nlet mensajeCliente = rawOutput;\nlet intent = \"CHAT\";  // valor por defecto\n\nif (match) {\n  intent = match[1].toUpperCase();\n  mensajeCliente = rawOutput.replace(match[0], '').trim();\n}\n\n// --- NUEVA VALIDACIÓN DE SEGURIDAD ---\n// Obtener el último mensaje del usuario (desde 'extraer datos1')\nconst mensajeUsuario = $('extraer datos1').first()?.json.mensaje || '';\nconst esConfirmacion = /^(si|sí|confirmo|ok|dale|acepto|confirmar|yes|ya|sale|vale|claro|por supuesto|adelante)$/i.test(mensajeUsuario.trim());\n\n// Si la intención es PEDIDO pero el usuario NO dijo una palabra de confirmación, la cambiamos a CHAT\nif (intent === 'PEDIDO' && !esConfirmacion) {\n  intent = 'CHAT';\n  // Restaurar mensaje original sin etiqueta para que el cliente vea el resumen completo\n  mensajeCliente = rawOutput.replace(intentRegex, '').trim();\n}\n// --- FIN VALIDACIÓN ---\n\n// Asegurar que la intención sea una de las esperadas por el Switch\nconst intentsValidos = [\"ACTUALIZAR\", \"PEDIDO\", \"CHAT\", \"ELSE\", \"HUMANO\"];\nif (!intentsValidos.includes(intent)) {\n  intent = \"CHAT\";\n}\n\n// Si después de limpiar no queda mensaje, usar un fallback\nif (!mensajeCliente) {\n  mensajeCliente = \"🤖 Procesando tu solicitud...\";\n}\n\nreturn {\n  json: {\n    output: mensajeCliente,\n    intent: intent,\n    extracted_data: {},  // Se llenará en la rama PEDIDO mediante el Cajero\n    chatid: chatid\n  }\n};"

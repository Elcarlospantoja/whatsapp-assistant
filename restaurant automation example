      "parameters": {
        "jsCode": "// ==============================================\n// DEPURACION: búsqueda tolerante a errores, confirmaciones, multi-tenant listo\n// ==============================================\n\n// 1. Recibir objeto limpio\nconst input = $input.first().json;\nconst clienteData = input.cliente || {};\nconst menuData = input.menu || [];\nconst salsasData = input.salsas || [];\nlet mensajeUsuario = input.mensaje_usuario || '';\n\n// 2. Función para normalizar texto (minúsculas, sin tildes, sin caracteres especiales)\nfunction normalizeText(text) {\n  if (!text) return '';\n  return text.toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-z0-9\\s]/g, '');\n}\n\n// 3. Normalizar el mensaje del cliente (se usa en todo el código)\nconst mensajeLimpio = mensajeUsuario.trim().toLowerCase();\nconst mensajeNorm = normalizeText(mensajeUsuario);   // ← AHORA DEFINIDA AL PRINCIPIO\n\n// 4. Optimización: fecha y día (una sola vez)\nconst ahora = new Date();\nconst formatter = new Intl.DateTimeFormat('es-MX', { timeZone: 'America/Mexico_City', weekday: 'long' });\nlet nombreDiaRaw = formatter.format(ahora);\nlet nombreDia = nombreDiaRaw.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n\n// 5. Distancia de Levenshtein y similitud\nfunction levenshtein(a, b) {\n  const an = a.length;\n  const bn = b.length;\n  if (an === 0) return bn;\n  if (bn === 0) return an;\n  const matrix = [];\n  for (let i = 0; i <= an; i++) matrix[i] = [i];\n  for (let j = 0; j <= bn; j++) matrix[0][j] = j;\n  for (let i = 1; i <= an; i++) {\n    for (let j = 1; j <= bn; j++) {\n      const cost = a[i-1] === b[j-1] ? 0 : 1;\n      matrix[i][j] = Math.min(\n        matrix[i-1][j] + 1,\n        matrix[i][j-1] + 1,\n        matrix[i-1][j-1] + cost\n      );\n    }\n  }\n  return matrix[an][bn];\n}\n\nfunction similitud(a, b) {\n  const maxLen = Math.max(a.length, b.length);\n  if (maxLen === 0) return 1;\n  return 1 - levenshtein(a, b) / maxLen;\n}\n\n// 6. Búsqueda difusa por palabra (compara keyword contra cada palabra del texto)\nfunction matchFuzzy(keyword, textoProducto) {\n  const palabras = textoProducto.split(/\\s+/);\n  return Math.max(...palabras.map(p => similitud(keyword, p)), 0);\n}\n\n// 7. Obtener promoción del día (usa la variable global nombreDia)\nfunction obtenerPromocionDelDia(menu) {\n  const promo = menu.find(p => \n    (p.categoria === 'Ofertas Semanales' || p.categoria === 'Promociones Fijas') &&\n    (normalizeText(p.nombre).includes(nombreDia) || normalizeText(p.descripcion || '').includes(nombreDia))\n  );\n  return promo || menu.find(p => p.categoria === 'Promociones Fijas') || menu[0];\n}\n\n// 8. Validar mensajes inválidos (audio, vacío, caracteres especiales)\nconst esAudio = ['[audio]', '🎤', 'audio', ''].includes(mensajeLimpio);\nconst esMuyCorto = mensajeLimpio.length < 2 && !esAudio;\nconst esSoloCaracteresEspeciales = /^[^a-záéíóúñü0-9]+$/.test(mensajeLimpio);\nlet esMensajeInvalido = esAudio || esMuyCorto || esSoloCaracteresEspeciales;\n\n// Si no hay menú, fallback\nif (menuData.length === 0) {\n  return [{\n    json: {\n      chatid: clienteData.id || '',\n      restaurante_id: clienteData.restaurante_id || '',\n      menu_context: '⚠️ Menú no disponible temporalmente. Intenta de nuevo.',\n      mensaje_usuario: mensajeUsuario\n    }\n  }];\n}\n\n// 9. Detección de confirmaciones (antes que todo)\nconst confirmaciones = ['si', 'sí', 'no', 'ok', 'dale', 'sale', 'ya', 'claro', 'confirmo', 'acepto', 'yes', 'vale', 'perfecto', 'listo', 'adelante', 'andale'];\nconst esConfirmacion = confirmaciones.includes(mensajeLimpio);\n\nif (esConfirmacion) {\n  const outputConfirm = {\n    chatid: clienteData.id || '',\n    restaurante_id: clienteData.restaurante_id || '',\n    nombre: clienteData.nombre || '',\n    direccion: clienteData.direccion || '',\n    notas_cliente: clienteData.notas_cliente || '',\n    menu_context: '',\n    mensaje_usuario: mensajeUsuario\n  };\n  return [{ json: outputConfirm }];\n}\n\n// 10. Detección de referencias vagas (usa mensajeNorm ya definido)\nconst referenciasVagas = [\n  'de esos', 'de ellos', 'los mismos', 'lo mismo', 'eso mismo', 'ese mismo',\n  'otro igual', 'repetir', 'quiero eso', 'dame eso', 'dame esos',\n  'quiero de esos', 'quiero los mismos', 'lo de siempre', 'otra vez',\n  'los mismos de antes', 'el de antes', 'quiero', 'lo que pedí',\n  'lo anterior', 'exactamente eso', 'justo eso', 'quiero lo mismo',\n  'solo eso', 'nada más eso', 'únicamente eso', 'lo de antes',\n  'de nuevo', 'repite', 'repite lo mismo', 'lo mismo de antes'\n];\n\nconst palabrasVagas = ['eso', 'ese', 'esos', 'esa', 'esas', 'aquello', 'eso mismo'];\n\nlet esReferenciaVaga = referenciasVagas.some(exp => mensajeNorm.includes(exp));\n\nif (!esReferenciaVaga) {\n  const palabrasMsg = mensajeNorm.trim().split(/\\s+/);\n  if (palabrasMsg.length <= 2 && palabrasMsg.every(p => palabrasVagas.includes(p))) {\n    esReferenciaVaga = true;\n  }\n}\n\nif (esReferenciaVaga) {\n  const outputVago = {\n    chatid: clienteData.id || '',\n    restaurante_id: clienteData.restaurante_id || '',\n    nombre: clienteData.nombre || '',\n    direccion: clienteData.direccion || '',\n    notas_cliente: clienteData.notas_cliente || '',\n    menu_context: '',\n    mensaje_usuario: mensajeUsuario\n  };\n  return [{ json: outputVago }];\n}\n\n// 11. Manejo de mensajes inválidos (audio, caracteres) con promoción del día\nif (esMensajeInvalido) {\n  const promo = obtenerPromocionDelDia(menuData);\n  let contexto = `🎙️ No entendí tu mensaje. Te ofrezco nuestra promoción del día: ${promo.nombre} $${promo.precio}\\nPor favor, escríbeme tu pedido en texto claro.`;\n  const outputInvalido = {\n    chatid: clienteData.id || '',\n    restaurante_id: clienteData.restaurante_id || '',\n    nombre: clienteData.nombre || '',\n    direccion: clienteData.direccion || '',\n    notas_cliente: clienteData.notas_cliente || '',\n    menu_context: contexto,\n    mensaje_usuario: mensajeUsuario\n  };\n  return [{ json: outputInvalido }];\n}\n\n// 12. Detección de saludos y menú completo\nconst saludos = ['hola', 'buenas', 'buenos dias', 'buenas tardes', 'buenas noches', 'saludos', 'hey', 'que tal', 'hola como estas'];\nconst esSaludo = saludos.some(s => mensajeNorm.includes(s));\n\nconst quiereMenuCompleto = /ver|mostrar|enseñar|todo el|el menu|todos los productos|qué productos|catálogo completo/.test(mensajeNorm) &&\n                           !/boneless|papas|nuggets|salchipulpos|coca|refresco|combo|promo/.test(mensajeNorm);\n\n// 13. Extraer palabras clave (stopwords)\nconst stopWords = ['hola','buenas','gracias','por','favor','quiero','quisiera','me','un','una','unos','unas','de','el','la','los','las','y','o','pero','si','no','con','sin','que','es','son','tengo','gustaria','quisiera','ver','mostrar','enseñar','todo','todos'];\nlet palabrasClave = mensajeNorm.split(/\\s+/).filter(w => w.length > 2 && !stopWords.includes(w));\n\n// 14. Si no hay palabras clave, no es saludo ni menú completo → ininteligible (ofrecer promo)\nif (palabrasClave.length === 0 && !esSaludo && !quiereMenuCompleto) {\n  const promo = obtenerPromocionDelDia(menuData);\n  let contexto = `❓ No entendí tu mensaje. Te ofrezco nuestra promoción del día: ${promo.nombre} $${promo.precio}\\nPor favor, escríbeme tu pedido en texto claro.`;\n  const outputIninteligible = {\n    chatid: clienteData.id || '',\n    restaurante_id: clienteData.restaurante_id || '',\n    nombre: clienteData.nombre || '',\n    direccion: clienteData.direccion || '',\n    notas_cliente: clienteData.notas_cliente || '',\n    menu_context: contexto,\n    mensaje_usuario: mensajeUsuario\n  };\n  return [{ json: outputIninteligible }];\n}\n\n// 15. Lógica de selección de productos\nlet productosSeleccionados = [];\n\nif (esSaludo || (palabrasClave.length === 0 && !quiereMenuCompleto)) {\n  const promo = obtenerPromocionDelDia(menuData);\n  if (promo) productosSeleccionados.push(promo);\n  const popularesNombres = ['boneless', 'papaboness', 'coca cola'];\n  for (const nombreBuscado of popularesNombres) {\n    const encontrado = menuData.find(p => normalizeText(p.nombre).includes(nombreBuscado));\n    if (encontrado && !productosSeleccionados.some(p => p.nombre === encontrado.nombre)) {\n      productosSeleccionados.push(encontrado);\n    }\n  }\n  if (productosSeleccionados.length === 0) productosSeleccionados = menuData.slice(0, 3);\n} \nelse if (quiereMenuCompleto) {\n  productosSeleccionados = menuData.slice(0, 12);\n} \nelse {\n  let encontrados = [];\n  // Coincidencia exacta (nombre o descripción)\n  for (const p of menuData) {\n    const textoBusqueda = normalizeText(p.nombre + ' ' + (p.descripcion || ''));\n    if (palabrasClave.some(kw => textoBusqueda.includes(kw))) {\n      encontrados.push(p);\n    }\n  }\n  // Si no hay exactos, usar fuzzy (umbral 0.72)\n  if (encontrados.length === 0) {\n    for (const p of menuData) {\n      const nombreNorm = normalizeText(p.nombre);\n      const descNorm = normalizeText(p.descripcion || '');\n      let mejorSim = 0;\n      for (const kw of palabrasClave) {\n        const simNombre = matchFuzzy(kw, nombreNorm);\n        const simDesc = matchFuzzy(kw, descNorm);\n        const sim = Math.max(simNombre, simDesc);\n        if (sim > mejorSim) mejorSim = sim;\n      }\n      if (mejorSim >= 0.72) encontrados.push(p);\n    }\n  }\n  if (encontrados.length === 0) {\n    const populares = menuData.filter(p => \n      normalizeText(p.nombre).includes('boneless') ||\n      normalizeText(p.nombre).includes('papaboness') ||\n      normalizeText(p.nombre).includes('coca cola')\n    );\n    productosSeleccionados = populares.length ? populares : menuData.slice(0, 3);\n  } else {\n    productosSeleccionados = encontrados.slice(0, 5);\n  }\n}\n\n// 16. Construir texto de productos\nlet productosText = '';\nfor (const p of productosSeleccionados) {\n  productosText += `${p.nombre} $${p.precio}`;\n  if (p.descripcion && p.descripcion.length < 70) {\n    productosText += `: ${p.descripcion}`;\n  } else if (p.descripcion) {\n    productosText += `: ${p.descripcion.substring(0, 60)}...`;\n  }\n  productosText += '\\n';\n}\n\n// 17. Salsas completas (siempre)\nconst salsasText = 'SALSAS: ' + salsasData.map(s => s.nombre).join(', ');\nconst contextoMenu = (productosText ? productosText + '\\n' : '') + salsasText;\n\n// 18. Output final\nconst output = {\n  chatid: clienteData.id || '',\n  restaurante_id: clienteData.restaurante_id || '',\n  nombre: clienteData.nombre || '',\n  direccion: clienteData.direccion || '',\n  notas_cliente: clienteData.notas_cliente || '',\n  menu_context: contextoMenu,\n  mensaje_usuario: mensajeUsuario\n};\n\nreturn [{ json: output }];"

        "jsCode": "// ==============================================\n// OBTENER TODOS LOS DATOS DE ENTRADA (sea como vengan)\n// ==============================================\n\n// 1. Obtener todos los ítems (pueden ser uno o varios)\nconst allItems = $input.all();\n\n// 2. Extraer todos los objetos JSON en un solo array plano\nlet combinedArray = [];\n\nfor (const item of allItems) {\n  const data = item.json;\n  \n  if (Array.isArray(data)) {\n    // Si el ítem es un array, agregamos sus elementos\n    combinedArray.push(...data);\n  } \n  else if (typeof data === 'object' && data !== null) {\n    // Si es un objeto, buscamos si tiene alguna propiedad que sea un array grande\n    let foundArray = false;\n    for (const key in data) {\n      if (Array.isArray(data[key]) && data[key].length > 0) {\n        // Asumimos que el primer array grande es el que nos interesa\n        combinedArray.push(...data[key]);\n        foundArray = true;\n        break;\n      }\n    }\n    if (!foundArray) {\n      // Si no encontró arrays, asumimos que el objeto mismo es un producto/salsa\n      combinedArray.push(data);\n    }\n  }\n}\n\n// Si después de todo sigue vacío, lanzar error\nif (combinedArray.length === 0) {\n  throw new Error('No se pudo extraer ningún dato del Merge');\n}\n\n// ==============================================\n// SEPARAR MENÚ Y SALSAS\n// ==============================================\n\nconst menu = [];\nconst salsas = [];\n\nfor (const item of combinedArray) {\n  // Los productos del menú tienen campo 'precio' (número)\n  if (item.hasOwnProperty('precio') && typeof item.precio === 'number') {\n    menu.push(item);\n  } \n  // Las salsas no tienen precio, pero tienen categoría específica\n  else if (item.hasOwnProperty('categoria') && \n           ['Dulce', 'Picante', 'Especial', 'Aderezo'].includes(item.categoria)) {\n    salsas.push(item);\n  }\n  // Por si acaso algún objeto no cumple, lo enviamos a salsas como fallback\n  else {\n    salsas.push(item);\n  }\n}\n\n// Al final, antes del return\nconst staticData = $getWorkflowStaticData('global');\nstaticData.menuGlobal = { menu, salsas, timestamp: Date.now() };\nreturn { json: { menu, salsas } };\n\n// ==============================================\n// RETORNAR OBJETO CON LAS DOS PROPIEDADES\n// ==============================================\n\nreturn {\n  json: {\n    menu: menu,\n    salsas: salsas\n  }\n};\n// Al final, antes del return\n"

        "jsCode": "// ==============================================\n// LIMPIAR DATOS: elimina campos innecesarios, conserva descripciones\n// ==============================================\n\n// 1. Obtener los dos objetos del Merge (cliente y menu+salsas)\nconst items = $input.all();\nlet clienteData = {};\nlet menuData = [];\nlet salsasData = [];\n\nfor (const item of items) {\n  const data = item.json;\n  // Si tiene 'menu' y 'salsas' es el catálogo\n  if (data.hasOwnProperty('menu') && data.hasOwnProperty('salsas')) {\n    menuData = data.menu;\n    salsasData = data.salsas;\n  } \n  // Si tiene 'id' y además 'nombre' (sin tener 'menu') es el cliente\n  else if (data.hasOwnProperty('id') && !data.hasOwnProperty('menu')) {\n    clienteData = {\n      id: data.id,\n      nombre: data.nombre,\n      direccion: data.direccion,\n      notas_cliente: data.notas_cliente\n    };\n  }\n}\n\n// 2. Obtener el mensaje del cliente desde el nodo 'extraer datos1'\nlet mensajeUsuario = '';\ntry {\n  const extraerNode = $('extraer datos1').first();\n  if (extraerNode && extraerNode.json.mensaje) {\n    mensajeUsuario = extraerNode.json.mensaje;\n  }\n} catch (e) {\n  console.error('No se pudo obtener mensaje del cliente:', e);\n}\n\n// 3. Limpiar menú: solo nombre, precio, categoría, descripción (si existe)\nconst menuLimpio = (menuData || []).map(p => ({\n  nombre: p.nombre,\n  precio: p.precio,\n  categoria: p.categoria,\n  descripcion: p.descripcion || ''   // incluimos descripción (vacía si no tiene)\n}));\n\n// 4. Limpiar salsas: solo nombre y categoría\nconst salsasLimpio = (salsasData || []).map(s => ({\n  nombre: s.nombre,\n  categoria: s.categoria\n}));\n\n// 5. Construir objeto de salida\nconst output = {\n  cliente: clienteData,\n  menu: menuLimpio,\n  salsas: salsasLimpio,\n  mensaje_usuario: mensajeUsuario\n};\n\nreturn [{ json: output }];"

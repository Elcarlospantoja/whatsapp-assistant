    {
      "parameters": {
        "jsCode": "// Recibir datos del flujo anterior\nconst input = $input.first().json;\nconst chatid = input.chatid || '';\n\n// Función para limpiar el mensaje de cualquier etiqueta o bloque JSON residual\nfunction cleanMessage(raw) {\n  if (!raw || typeof raw !== 'string') return '';\n  \n  let cleaned = raw;\n  \n  // Eliminar cualquier etiqueta [INTENT: ...] que pudiera haber quedado\n  cleaned = cleaned.replace(/\\[INTENT:\\s*\\w+\\s*\\]/gi, '');\n  \n  // Eliminar bloques de código markdown (```json ... ```)\n  cleaned = cleaned.replace(/```(?:json)?[\\s\\S]*?```/g, '');\n  \n  // Eliminar objetos JSON sueltos (por si acaso)\n  cleaned = cleaned.replace(/\\{[\\s\\S]*?\\}/g, '');\n  \n  // Eliminar backticks residuales\n  cleaned = cleaned.replace(/`{1,3}/g, '');\n  \n  // Eliminar espacios múltiples y recortar\n  cleaned = cleaned.replace(/\\s+/g, ' ').trim();\n  \n  return cleaned;\n}\n\n// Obtener mensaje limpio\nlet finalMessage = cleanMessage(input.output || '');\n\n// Si después de limpiar queda vacío, poner un fallback amigable\nif (!finalMessage) {\n  finalMessage = '🤗 Lo siento, estamos recibiendo muchos mensajes por el momento. Inténtalo de nuevo en 1 minuto, por favor.';\n}\n\n// Retornar solo lo necesario para el HTTP Request\nreturn {\n  json: {\n    output: finalMessage,\n    chatid: chatid\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2928,
        1632
      ],
      "id": "5776b46e-7547-4752-ab78-cea8efccc7b5",
      "name": "Preparar mensaje final"
    },
    {
      "parameters": {
        "jsCode": "// ==========================================\n// ANTI-SPAM + ANTI-DUPLICADOS (MODO BLOQUEO)\n// ==========================================\n\nconst redis = require('redis');\nconst crypto = require('crypto');\n\n// ---------- ⚙️ CONFIGURACIÓN (AJUSTA ESTOS VALORES) ----------\nconst RATE_LIMIT_SECONDS = 5;     // Tiempo mínimo entre mensajes del mismo chat\nconst DEDUP_TTL_SECONDS = 50;     // Tiempo para bloquear mensajes de texto idéntico\nconst ENABLE_RATE_LIMIT = true;   // Activar límite por tiempo\nconst ENABLE_DEDUP = true;        // Activar bloqueo de mensajes repetidos\n// -----------------------------------------------------------\n\nconst client = redis.createClient({\n  url: 'redis://redis:6379',\n  socket: { connectTimeout: 3000 }\n});\n\nclient.on('error', (err) => console.error('[REDIS ERROR]', err));\n\ntry {\n  await client.connect();\n  \n  const webhookData = $input.first().json;\n  const chatId = webhookData.body?.data?.key?.remoteJid;\n  let messageText = webhookData.body?.data?.message?.conversation || \n                    webhookData.body?.data?.message?.extendedTextMessage?.text || '';\n  \n  if (!chatId) {\n    console.warn('[FLOW] No se encontró chatId, permitiendo paso');\n    await client.quit();\n    return $input.all();\n  }\n  \n  // ----- 1️⃣ RATE LIMIT (Límite por tiempo) -----\n  if (ENABLE_RATE_LIMIT) {\n    const rateKey = `ratelimit:${chatId}`;\n    const rateResult = await client.set(rateKey, Date.now().toString(), {\n      NX: true,\n      EX: RATE_LIMIT_SECONDS\n    });\n    \n    if (rateResult === null) {\n      console.log(`[RATE LIMIT] 🚫 Mensaje bloqueado por velocidad (${RATE_LIMIT_SECONDS}s)`);\n      await client.quit();\n      return []; // DETIENE EL FLUJO\n    }\n  }\n  \n  // ----- 2️⃣ DEDUPLICACIÓN DE CONTENIDO (Mismo texto) -----\n  if (ENABLE_DEDUP && messageText) {\n    const normalizedText = messageText.trim().toLowerCase().replace(/\\s+/g, ' ');\n    const hash = crypto.createHash('md5').update(normalizedText).digest('hex');\n    const dedupKey = `dedup:${chatId}:${hash}`;\n    \n    const dedupResult = await client.set(dedupKey, '1', { NX: true, EX: DEDUP_TTL_SECONDS });\n    \n    if (dedupResult === null) {\n      console.log(`[DEDUP] 🔁 Mensaje duplicado bloqueado: \"${normalizedText}\"`);\n      await client.quit();\n      return []; // DETIENE EL FLUJO\n    }\n  }\n  \n  // Si llegó hasta aquí, el mensaje es válido\n  await client.quit();\n  console.log('[FLOW] ✅ Mensaje permitido');\n  return $input.all();\n  \n} catch (error) {\n  console.error('[ERROR]', error.message);\n  try { await client.quit(); } catch {}\n  // En caso de fallo de Redis, permitir el paso para no perder mensajes legítimos\n  console.warn('[FLOW] Redis no disponible, permitiendo paso por seguridad');\n  return $input.all();\n}"
      },

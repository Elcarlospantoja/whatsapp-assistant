########################################
# Evolution API Configuration
########################################

# API Authentication Key - Protege tu API con esta clave
AUTHENTICATION_API_KEY=your_evolution_api_key_here

# Server Configuration
SERVER_TYPE=http
SERVER_PORT=8080
CORS_ORIGIN=*
CORS_METHODS=POST,GET,PUT,DELETE
CORS_CREDENTIALS=true

# Log Configuration
LOG_LEVEL=ERROR,WARN,DEBUG,INFO,LOG,VERBOSE,DARK
LOG_COLOR=true
LOG_BAILEYS=error

########################################
# Database Configuration (PostgreSQL)
########################################

POSTGRES_DATABASE=evolution_db
POSTGRES_USERNAME=evolution_user
POSTGRES_PASSWORD=your_postgres_password_here

########################################
# Storage Configuration
########################################

# Store configuration
STORE_MESSAGES=true
STORE_MESSAGE_UP=true
STORE_CONTACTS=true
STORE_CHATS=true

# Clean store on instance deletion
CLEAN_STORE_CLEANING_TERMINAL=false
CLEAN_STORE_MESSAGES=true
CLEAN_STORE_MESSAGE_UP=true
CLEAN_STORE_CONTACTS=true
CLEAN_STORE_CHATS=true

########################################
# n8n Configuration
########################################

# n8n Encryption Key - GUÁRDALA BIEN, sin esta no podrás descifrar credenciales
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

########################################
# WhatsApp Configuration
########################################

# WhatsApp version
CONFIG_SESSION_PHONE_CLIENT=Evolution API
CONFIG_SESSION_PHONE_NAME=Chrome
CONFIG_SESSION_PHONE_VERSION=2.3000.1023204200

########################################
# Webhook Configuration
########################################

# Webhook events
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# Events to track
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_MESSAGES_SET=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_DELETE=true
WEBHOOK_EVENTS_SEND_MESSAGE=true
WEBHOOK_EVENTS_CONTACTS_SET=true
WEBHOOK_EVENTS_CONTACTS_UPSERT=true
WEBHOOK_EVENTS_CONTACTS_UPDATE=true
WEBHOOK_EVENTS_PRESENCE_UPDATE=true
WEBHOOK_EVENTS_CHATS_SET=true
WEBHOOK_EVENTS_CHATS_UPSERT=true
WEBHOOK_EVENTS_CHATS_UPDATE=true
WEBHOOK_EVENTS_CHATS_DELETE=true
WEBHOOK_EVENTS_GROUPS_UPSERT=true
WEBHOOK_EVENTS_GROUPS_UPDATE=true
WEBHOOK_EVENTS_GROUP_PARTICIPANTS_UPDATE=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_CALL=true
WEBHOOK_EVENTS_NEW_JWT_TOKEN=false

########################################
# QR Code Configuration
########################################

QRCODE_LIMIT=30
QRCODE_COLOR=#198754

########################################
# Authentication Type
########################################

AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY_EXPOSE_IN_SWAGGER=true
AUTHENTICATION_API_KEY_PREFIX=Bearer

########################################
#ANY DOMAIN YOU WANT
########################################
DOMAIN=your-domain.duckdns.org
